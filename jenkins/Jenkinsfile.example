pipeline {
    agent any

    environment {
        IMAGE_NAME = 'your-app'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
        STAGE_HOST = credentials('stage-host')
        OPERATION_HOST = credentials('operation-host')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build image') {
            steps {
                sh 'docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .'
            }
            post {
                always {
                    jiraSendBuildInfo()
                }
            }
        }

        stage('Test') {
            steps {
                sh './gradlew test'
            }
        }

        stage('Deploy stage') {
            steps {
                sshagent(credentials: ['stage-ssh-key']) {
                    sh '''
                      docker save ${IMAGE_NAME}:${IMAGE_TAG} | gzip > app-image.tar.gz
                      scp app-image.tar.gz ubuntu@${STAGE_HOST}:/tmp/app-image.tar.gz
                      ssh ubuntu@${STAGE_HOST} "gunzip -c /tmp/app-image.tar.gz | docker load && docker compose -f /opt/app/docker-compose.yml up -d"
                    '''
                }
            }
            post {
                always {
                    jiraSendDeploymentInfo environmentId: 'stage', environmentName: 'stage', environmentType: 'staging'
                }
            }
        }

        stage('Approve operation') {
            steps {
                input message: 'Deploy to operation?', ok: 'Deploy'
            }
        }

        stage('Deploy operation') {
            steps {
                sshagent(credentials: ['operation-ssh-key']) {
                    sh '''
                      scp app-image.tar.gz ubuntu@${OPERATION_HOST}:/tmp/app-image.tar.gz
                      ssh ubuntu@${OPERATION_HOST} "gunzip -c /tmp/app-image.tar.gz | docker load && docker compose -f /opt/app/docker-compose.yml up -d"
                    '''
                }
            }
            post {
                always {
                    jiraSendDeploymentInfo environmentId: 'operation', environmentName: 'operation', environmentType: 'production'
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
